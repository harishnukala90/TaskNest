rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       AUTH HELPERS
    ========================= */

    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isProvider() {
      return resource.data.providerId == request.auth.uid;
    }

    /* =========================
       USERS COLLECTION
    ========================= */

    match /users/{userId} {

      allow read: if isLoggedIn();

      allow create: if isLoggedIn()
        && request.auth.uid == userId;

      allow update: if isOwner(userId);

      allow delete: if false;
    }

    /* =========================
       JOBS COLLECTION
    ========================= */

    match /jobs/{jobId} {

      /* ---------- READ ---------- */
      allow read: if isLoggedIn();

      /* ---------- CREATE ---------- */
      allow create: if isLoggedIn()
        && request.resource.data.providerId
           == request.auth.uid;

      /* ---------- DELETE ---------- */
      allow delete: if isLoggedIn()
        && isProvider();

      /* ---------- UPDATE LOGIC ---------- */
      allow update: if isLoggedIn() && (
        
        /* PROVIDER FULL CONTROL */
        isProvider()

        ||

        /* WORKER APPLY */
        workerApplying()

        ||

        /* WORKER CANCEL APPLY */
        workerCancelling()
      );

      /* =========================
         WORKER ACTION CHECKS
      ========================= */

      function workerApplying() {
        return
          request.auth.uid != resource.data.providerId
          &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['appliedWorkers'])
          &&
          !resource.data.appliedWorkers.hasAny([request.auth.uid])
          &&
          request.resource.data.appliedWorkers.size()
            == resource.data.appliedWorkers.size() + 1
          &&
          request.resource.data.appliedWorkers
            .hasAny([request.auth.uid]);
      }

      function workerCancelling() {
        return
          request.auth.uid != resource.data.providerId
          &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['appliedWorkers'])
          &&
          request.resource.data.appliedWorkers == resource.data.appliedWorkers.delete(request.auth.uid);
      }
    }
  }
}